{
  "name": "llm-eval-switch",
  "version": "1.0.0",
  "description": "Cross-platform LLM evaluation desktop app inspired by cc-switch.",
  "main": "src/main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "check": "node scripts/smoke-check.js",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win"
  },
  "dependencies": {
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "electron": "^39.2.4",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "io.llmeval.switch",
    "productName": "LLM Eval Switch",
    "files": [
      "src/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "src/**"
    ],
    "extraResources": [
      {
        "from": "datasets",
        "to": "datasets"
      },
      {
        "from": "eval_config.yaml",
        "to": "eval_config.yaml"
      },
      {
        "from": "dimensions_seed.json",
        "to": "dimensions_seed.json"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    }
  }
}
